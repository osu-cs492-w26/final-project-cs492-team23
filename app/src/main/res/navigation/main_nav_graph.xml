<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_nav_graph"
    app:startDestination="@id/home">

    <fragment
        android:id="@+id/home"
        android:name="edu.oregonstate.cs492.MovieWatchListManager.ui.HomeFragment"
        android:label="Movie Watchlist Manager"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_category_details"
            app:destination="@id/category_details" />
    </fragment>

    <fragment
        android:id="@+id/category_details"
        android:name="edu.oregonstate.cs492.MovieWatchListManager.ui.CategoryDetailsFragment"
        android:label="{categoryTitle}"
        tools:layout="@layout/fragment_category_details">
        <argument
            android:name="categoryTitle"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/search"
        android:name="edu.oregonstate.cs492.MovieWatchListManager.ui.SearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search" />

    <fragment
        android:id="@+id/saved"
        android:name="edu.oregonstate.cs492.MovieWatchListManager.ui.SavedFragment"
        android:label="My List"
        tools:layout="@layout/fragment_saved" />

    <fragment
        android:id="@+id/history"
        android:name="edu.oregonstate.cs492.MovieWatchListManager.ui.HistoryFragment"
        android:label="Watch History"
        tools:layout="@layout/fragment_history" />

</navigation>